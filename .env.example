# FireWatch AI — Environment Configuration

# Local computer vision model path.
# For local development, place best.pt in the project root or update this path.
# If you prefer a cleaner root, put it in ignored local_assets/ and set:
# FIRE_DETECT_MODEL=./local_assets/best.pt
# If the model is unavailable, the backend falls back to lighter detection paths where possible.
FIRE_DETECT_MODEL=./best.pt

# Hosted model download from Hugging Face Hub.
# Recommended for Render deployment instead of committing large .pt files to GitHub.
HF_MODEL_REPO=
HF_MODEL_FILENAME=best.pt
HF_SEG_MODEL_REPO=
HF_SEG_MODEL_FILENAME=best.pt
# Only set HF_TOKEN when the Hugging Face model repo is private.
HF_TOKEN=

# Inference mode:
# - local: backend loads YOLO locally (best for your laptop or paid RAM instances)
# - remote: backend forwards YOLO requests to a separate inference service
INFERENCE_MODE=local
INFERENCE_SERVICE_URL=
REMOTE_INFERENCE_TIMEOUT_SECONDS=300

# API Keys
# Required for RAG Assistant answer synthesis
GROQ_API_KEY=your_groq_api_key_here

# Backend Configuration
BACKEND_URL=http://localhost:8000
# Vercel-only frontend variable. Set this in Vercel to your Render backend URL.
VITE_BACKEND_URL=http://localhost:8000
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Emergency Alert Configuration
# Safe default: demo mode records prepared alerts without contacting real people.
# For live email: set AUTO_ALERTS_ENABLED=true and ALERT_MODE=email.
ALERT_MODE=demo
AUTO_ALERTS_ENABLED=false
ALERT_CONFIRMATION_FRAMES=3
ALERT_COOLDOWN_SECONDS=300

# The sender email used for the Gmail API (OAuth2)
REMINDER_EMAIL_SENDER=your_email@gmail.com
# Comma-separated list of recipient emails
REMINDER_EMAIL_RECEIVERS=stakeholder1@email.com,stakeholder2@email.com
# Optional local-only Gmail OAuth token path. Prefer secrets/ over docs/ for private files.
GOOGLE_TOKEN_FILE=secrets/token.json
